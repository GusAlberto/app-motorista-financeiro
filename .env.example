# =============================================================================
# app-motorista — Environment Variables Template
# =============================================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env.local  →  cp .env.example .env.local
#   2. Replace placeholder values with real values from your Supabase Dashboard
#      → Project Settings → API
#   3. NEVER commit .env.local to git (it is already in .gitignore)
#
# NEXT_PUBLIC_* variables are safe to expose to the browser (limited by RLS).
# Non-prefixed variables are server-only secrets — never send to browser.
# =============================================================================

# Supabase Project URL (safe to expose — RLS enforces authorization)
# Found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Anon Key (safe to expose — public, limited by RLS policies)
# Found in: Supabase Dashboard → Settings → API → Project API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase Service Role Key (SECRET — server-only, NEVER expose to browser)
# Found in: Supabase Dashboard → Settings → API → Project API Keys → service_role
# Used only in server-side code (Server Actions, Route Handlers, middleware)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# =============================================================================
# Application
# =============================================================================

# Public URL of your deployed app (used for redirects and OG tags)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
