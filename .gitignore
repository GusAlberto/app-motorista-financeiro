# =============================================================================
# app-motorista — .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
dist/
build/

# Environment variables (SECRET — never commit real keys)
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Supabase local data (not migrations — those go in git)
supabase/.branches
supabase/.temp
supabase/functions/.zip

# Test coverage
coverage/
.nyc_output

# PWA
public/sw.js
public/workbox-*.js
